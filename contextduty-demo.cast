{"version":3,"term":{"cols":107,"rows":33,"type":"xterm-256color","theme":{"fg":"#e4e4e4","bg":"#141414","palette":"#242424:#fc6b83:#3fa266:#d2943e:#81a1c1:#b48ead:#88c0d0:#e4e4e4:#e4e4e4:#fc6b83:#70b489:#f1b467:#87a6c4:#b48ead:#88c0d0:#e4e4e4"}},"timestamp":1777793440,"env":{"SHELL":"/bin/zsh"}}
[0.046, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                                          \r \r"]
[0.000, "o", "\r\u001b[0m\u001b[27m\u001b[24m\u001b[Jvasanthkumarpujari@vasanths-MacBook-Pro contextduty % \u001b[K\u001b[?2004h"]
[8.043, "o", "\u001b[7mbash demo/demo.sh\u001b[27m"]
[0.296, "o", "\u001b[17D\u001b[27mb\u001b[27ma\u001b[27ms\u001b[27mh\u001b[27m \u001b[27md\u001b[27me\u001b[27mm\u001b[27mo\u001b[27m/\u001b[27md\u001b[27me\u001b[27mm\u001b[27mo\u001b[27m.\u001b[27ms\u001b[27mh\u001b[?2004l\r\r\n"]
[0.015, "o", "\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.001, "o", "\u001b[1m\u001b[36m  Scene 1 — This is what ends up in your AI prompt\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[33m▶ A realistic mixed log/context file an engineer might paste into Cursor:\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[2m$ cat demo/input.txt\u001b[0m\r\n\r\n"]
[0.003, "o", "# Sample context file — the kind of mixed data that ends up in AI prompts\r\n# ContextDuty detects and redacts these before they leave your machine\r\n\r\n[2026-05-03 09:14] Reminder job started\r\n[2026-05-03 09:14] Sending to: meera.sharma@apollohospitals.com\r\n[2026-05-03 09:14] Auth: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJwcm9kIn0.abc123\r\n[2026-05-03 09:14] AWS region: us-east-1, key: AKIA1234567890ABCDEF\r\n[2026-05-03 09:14] Support contact: +1 415-555-1212\r\n[2026-05-03 09:14] API key in config: sk_live_9Xk2mPqRvL8nJwTdYcBe3F\r\n[2026-05-03 09:14] SMTP error: connection timeout on port 587\r\n[2026-05-03 09:14] Retrying in 30s...\r\n"]
[1.010, "o", "\r\n\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\u001b[1m\u001b[36m  Scene 2 — Scan: detect what's sensitive\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[33m▶ Run contextduty scan in warn mode\u001b[0m\r\n\u001b[2m$ contextduty scan demo/input.txt\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.392, "o", "{\r\n  \"findings_count\": 5,\r\n  \"detector_counts\": {\r\n    \"email\": 1,\r\n    \"bearer_token\": 1,\r\n    \"aws_key\": 1,\r\n    \"phone\": 1,\r\n    \"api_key\": 1\r\n  },\r\n  \"blocked\": false\r\n}\r\n"]
[0.005, "o", "\r\n"]
[0.000, "o", "\u001b[32m✓ Findings reported. Nothing changed. No cloud call made.\u001b[0m\r\n"]
[1.008, "o", "\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\u001b[1m\u001b[36m  Scene 3 — Redact: mask before the LLM sees it\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[1m\u001b[33m▶ Redact the file — sensitive values replaced with deterministic masks\u001b[0m\r\n\u001b[2m$ contextduty redact --in demo/input.txt --out /tmp/contextduty-clean.txt\u001b[0m\r\n\r\n"]
[0.064, "o", "{\r\n  \"findings_count\": 5,\r\n  \"detector_counts\": {\r\n    \"email\": 1,\r\n    \"bearer_token\": 1,\r\n    \"aws_key\": 1,\r\n    \"phone\": 1,\r\n    \"api_key\": 1\r\n  },\r\n  \"blocked\": false\r\n}\r\n"]
[0.006, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[33m▶ What the LLM receives instead:\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m$ cat /tmp/contextduty-clean.txt\u001b[0m\r\n\r\n"]
[0.001, "o", "# Sample context file — the kind of mixed data that ends up in AI prompts\r\n# ContextDuty detects and redacts these before they leave your machine\r\n\r\n[2026-05-03 09:14] Reminder job started\r\n[2026-05-03 09:14] Sending to: <EMAIL_bae9a90adc>\r\n[2026-05-03 09:14] Auth: <BEARER_TOKEN_024d70111e>\r\n[2026-05-03 09:14] AWS region: us-east-1, key: <AWS_KEY_743554670c>\r\n[2026-05-03 09:14] Support contact: +<PHONE_4f7a10f4cb>\r\n[2026-05-03 09:14] API key in config: <API_KEY_4294945d6e>\r\n[2026-05-03 09:14] SMTP error: connection timeout on port 587\r\n[2026-05-03 09:14] Retrying in 30s...\r\n"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[32m✓ Email, token, AWS key, phone — all masked. Same mask every time (deterministic).\u001b[0m\r\n"]
[1.004, "o", "\r\n\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.001, "o", "\u001b[1m\u001b[36m  Scene 4 — Block mode: fail CI if secrets are found\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[0.008, "o", "\u001b[1m\u001b[33m▶ Switch policy to block mode — this is what you put in CI\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m$ contextduty scan demo/input.txt --policy /tmp/block-policy.json\u001b[0m\r\n\r\n"]
[0.056, "o", "{\r\n  \"findings_count\": 5,\r\n  \"detector_counts\": {\r\n    \"email\": 1,\r\n    \"bearer_token\": 1,\r\n    \"aws_key\": 1,\r\n    \"phone\": 1,\r\n    \"api_key\": 1\r\n  },\r\n  \"blocked\": true\r\n}\r\nBLOCKED by policy (/tmp/block-policy.json)\r\n"]
[0.006, "o", "\r\n"]
[0.000, "o", "\u001b[31mExit code: 2\u001b[0m\r\n"]
[0.000, "o", "\u001b[32m✓ Non-zero exit → pipeline blocked. Commit never reaches the remote.\u001b[0m\r\n"]
[1.002, "o", "\r\n\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[36m  Scene 5 — Custom detector: no code changes needed\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[0.006, "o", "\u001b[1m\u001b[33m▶ Input with org-specific patterns (not covered by any built-in detector):\u001b[0m\r\n"]
[0.001, "o", "\u001b[2m$ cat /tmp/custom-input.txt\u001b[0m\r\n\r\n"]
[0.002, "o", "Assigned engineer: EMP-482910\r\nRelated ticket: TICKET-OPS-0042\r\nServer: api.internal.corp.com\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[33m▶ Policy with custom regex — no Python changes needed:\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m$ cat /tmp/custom-policy.json\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.002, "o", "{\r\n  \"mode\": \"redact\",\r\n  \"detectors\": [],\r\n  \"custom_detectors\": {\r\n    \"employee_id\": \"\\\\bEMP-[0-9]{6}\\\\b\",\r\n    \"internal_ticket\": \"\\\\bTICKET-[A-Z]{3}-[0-9]{4}\\\\b\"\r\n  }\r\n}\r\n"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[33m▶ Scan result:\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m$ contextduty redact --in /tmp/custom-input.txt --out /tmp/custom-clean.txt --policy /tmp/custom-policy.json\u001b[0m\r\n"]
[0.043, "o", "{\r\n  \"findings_count\": 2,\r\n  \"detector_counts\": {\r\n    \"employee_id\": 1,\r\n    \"internal_ticket\": 1\r\n  },\r\n  \"blocked\": false\r\n}\r\n"]
[0.005, "o", "\r\n"]
[0.001, "o", "Assigned engineer: <EMPLOYEE_ID_87e2e7e522>\r\nRelated ticket: <INTERNAL_TICKET_a8324fad54>\r\nServer: api.internal.corp.com\r\n"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[32m✓ EMP-482910 and TICKET-OPS-0042 redacted with zero code changes.\u001b[0m\r\n"]
[1.008, "o", "\r\n"]
[0.000, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[36m  Done\u001b[0m\r\n"]
[0.001, "o", "\u001b[2m────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[1mContextDuty — local-first, policy-driven, zero dependencies.\u001b[0m\r\n\r\n  pip install contextduty\r\n  contextduty init\r\n  contextduty scan <file>\r\n\r\n\u001b[2mgithub.com/SHUBHAGYTA24/contextduty\u001b[0m\r\n\r\n"]
[0.001, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                                          \r \r"]
