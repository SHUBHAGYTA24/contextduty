{
  "extends": "soc2-baseline.json",
  "mode": "block",
  "detectors": [
    "ssn",
    "npi_number",
    "dea_number",
    "icd10_code",
    "credit_card",
    "passport"
  ],
  "custom_detectors": {
    "medical_record_number": "\\bMRN[-:]?\\s*[0-9]{6,10}\\b",
    "hipaa_dob": "\\b(?:DOB|Date of Birth|Birth Date)\\s*[=:]\\s*\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}\\b"
  }
}